# ──────────────────────────────────────────────────────────────
# AI — GitHub Models API (FREE with your GitHub subscription)
# ──────────────────────────────────────────────────────────────
# How to get your token (takes 60 seconds):
#   1. github.com → Settings → Developer settings
#   2. Personal access tokens → Fine-grained tokens → Generate new token
#   3. Any name, any expiry — NO permissions needed
#   4. Paste the token below
#
# Without this token the API still works using rule-based regex extraction.
GITHUB_TOKEN=github_pat_...

# ──────────────────────────────
# Database
# ──────────────────────────────
# SQLite (dev — leave as is)
DATABASE_URL=sqlite+aiosqlite:///./pdfapi.db

# PostgreSQL (prod — Railway injects this automatically when you add a PostgreSQL plugin)
# Both postgres:// and postgresql:// schemes are auto-converted to asyncpg.
# DATABASE_URL=postgresql://user:password@host:5432/pdfapi

# ──────────────────────────────
# API
# ──────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string   # used to sign internal tokens
API_KEY_PREFIX=pdfa_                               # all user keys look like pdfa_xxx
MAX_UPLOAD_MB=20
APP_URL=https://pdfjson.inksky.net                 # used in Stripe redirect URLs

# Comma-separated CORS origins. Use * for local dev, restrict in production.
# CORS_ORIGINS=https://pdfjson.inksky.net

# ──────────────────────────────
# Stripe (Phase 2 — optional for MVP)
# ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_STARTER=price_xxx   # $19/mo — 500 parses
STRIPE_PRICE_PRO=price_xxx       # $49/mo — 3000 parses
STRIPE_PRICE_SCALE=price_xxx     # $149/mo — 20000 parses

# ──────────────────────────────
# Limits
# ──────────────────────────────
# Free tier parses per month (default: 3). Paid tier limits are hardcoded in billing.py.
FREE_MONTHLY_LIMIT=3
